<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simulado Enade - História da Psicologia</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f4f8; color: #2c3e50; line-height: 1.6; padding: 20px; }
        .container { max-width: 850px; margin: auto; background: #fff; padding: 35px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
        
        .stats-panel { display: flex; justify-content: space-between; background: #34495e; color: white; padding: 15px 25px; border-radius: 8px; margin-bottom: 30px; font-weight: bold; flex-wrap: wrap; gap: 10px; }
        .stats-panel span { font-size: 1.1em; }
        .acertos { color: #2ecc71; }
        .erros { color: #e74c3c; }

        .question-header { font-size: 1.3em; font-weight: bold; margin-bottom: 20px; color: #2980b9; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px; }
        .enunciado { margin-bottom: 15px; white-space: pre-wrap; font-size: 1.1em; }
        .assercoes-box { background-color: #f8f9fa; border-left: 4px solid #3498db; padding: 15px 20px; margin-bottom: 25px; font-style: italic; border-radius: 0 5px 5px 0; }
        
        .options-container { margin-bottom: 25px; }
        .option-label { display: block; background: #fff; padding: 15px; margin-bottom: 12px; border-radius: 6px; cursor: pointer; border: 2px solid #ecf0f1; transition: all 0.2s ease; }
        .option-label:hover { border-color: #3498db; background: #f0f8ff; }
        .option-label.correct { border-color: #2ecc71; background: #eafaf1; }
        .option-label.incorrect { border-color: #e74c3c; background: #fceae9; }
        input[type="radio"] { margin-right: 12px; transform: scale(1.2); }
        
        .nav-buttons { display: flex; gap: 15px; margin-top: 20px; }
        .btn { background: #3498db; color: #fff; border: none; padding: 15px 25px; font-size: 1.1em; font-weight: bold; border-radius: 6px; cursor: pointer; flex: 1; transition: 0.3s; }
        .btn:hover { background: #2980b9; }
        .btn:disabled { background: #bdc3c7; cursor: not-allowed; }
        .btn-secondary { background: #95a5a6; }
        .btn-secondary:hover { background: #7f8c8d; }
        
        .feedback { margin-top: 25px; padding: 20px; border-radius: 8px; display: none; font-size: 1.05em; }
        .feedback.correct-box { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .feedback.incorrect-box { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .explanation { margin-top: 10px; font-weight: normal; line-height: 1.5; }

        /* Grid de navegação rápida */
        .question-grid { margin-top: 40px; padding-top: 20px; border-top: 2px solid #ecf0f1; display: flex; flex-wrap: wrap; gap: 8px; }
        .grid-btn { width: 40px; height: 40px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; background: #ecf0f1; color: #7f8c8d; transition: 0.2s; }
        .grid-btn:hover { background: #bdc3c7; color: #2c3e50; }
        .grid-btn.answered-correct { background: #2ecc71; color: white; border: 1px solid #27ae60; }
        .grid-btn.answered-incorrect { background: #e74c3c; color: white; border: 1px solid #c0392b; }
        .grid-btn.current { border: 3px solid #2c3e50; transform: scale(1.1); box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 10; color: #2c3e50; background: #fff;}
        
        .reset-btn { background: #e74c3c; margin-top: 30px; width: 100%; }
        .reset-btn:hover { background: #c0392b; }
    </style>
</head>
<body>

<div class="container">
    <div class="stats-panel">
        <span>Questão <span id="current-question-num">1</span> de <span id="total-questions">0</span></span>
        <span class="acertos">Acertos: <span id="score-correct">0</span></span>
        <span class="erros">Erros: <span id="score-incorrect">0</span></span>
        <span>Aproveitamento: <span id="score-percent">0</span>%</span>
    </div>

    <div id="quiz-area">
        <div class="question-header" id="question-title"></div>
        <div class="enunciado" id="enunciado-text"></div>
        <div class="assercoes-box" id="assercoes-area" style="display: none;"></div>
        <div class="options-container" id="options-area"></div>
        
        <div class="nav-buttons">
            <button class="btn btn-secondary" id="prev-btn" onclick="navegar(-1)">&#8592; Voltar</button>
            <button class="btn" id="submit-btn" onclick="verificarResposta()">Confirmar Resposta</button>
            <button class="btn btn-secondary" id="next-btn" onclick="navegar(1)">Avançar &#8594;</button>
        </div>
        
        <div id="feedback-area" class="feedback">
            <strong id="feedback-title"></strong>
            <div id="feedback-explanation" class="explanation"></div>
        </div>

        <div class="question-grid" id="grid-area"></div>
        
        <button class="btn reset-btn" onclick="zerarSimulado()">Limpar Progresso e Recomeçar</button>
    </div>
</div>

<script>
