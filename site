    let currentIndex = 0;
    let progresso = JSON.parse(localStorage.getItem('simulado_psicologia_v2')) || {
        respostas: {}, // Guarda { idDaQuestao: alternativaEscolhida }
        acertos: 0,
        erros: 0
    };

    function initQuiz() {
        if(questoes.length === 0) {
            document.getElementById("enunciado-text").innerText = "As questões não foram encontradas. Verifique a variável 'questoes' no código fonte!";
            document.getElementById("submit-btn").style.display = "none";
            return;
        }
        document.getElementById("total-questions").innerText = questoes.length;
        gerarGridNavegacao();
        atualizarEstatisticas();
        carregarQuestao();
    }

    function salvarProgresso() {
        localStorage.setItem('simulado_psicologia_v2', JSON.stringify(progresso));
        atualizarEstatisticas();
        gerarGridNavegacao();
    }

    function atualizarEstatisticas() {
        document.getElementById("score-correct").innerText = progresso.acertos;
        document.getElementById("score-incorrect").innerText = progresso.erros;
        let totalRespondidas = progresso.acertos + progresso.erros;
        let percent = totalRespondidas === 0 ? 0 : Math.round((progresso.acertos / totalRespondidas) * 100);
        document.getElementById("score-percent").innerText = percent;
    }

    function gerarGridNavegacao() {
        const grid = document.getElementById("grid-area");
        grid.innerHTML = "";
        questoes.forEach((q, index) => {
            const btn = document.createElement("button");
            btn.className = "grid-btn";
            btn.innerText = index + 1;
            btn.onclick = () => irParaQuestao(index);
            
            if (index === currentIndex) btn.classList.add("current");
            
            if (progresso.respostas[q.id] !== undefined) {
                if (progresso.respostas[q.id] === q.resposta_correta) {
                    btn.classList.add("answered-correct");
                } else {
                    btn.classList.add("answered-incorrect");
                }
            }
            grid.appendChild(btn);
        });
    }

    function irParaQuestao(index) {
        currentIndex = index;
        carregarQuestao();
        gerarGridNavegacao();
    }

    function navegar(direcao) {
        let novoIndex = currentIndex + direcao;
        if (novoIndex >= 0 && novoIndex < questoes.length) {
            irParaQuestao(novoIndex);
        }
    }

    function carregarQuestao() {
        const questao = questoes[currentIndex];
        document.getElementById("current-question-num").innerText = currentIndex + 1;
        document.getElementById("enunciado-text").innerText = questao.enunciado;
        
        const assercoesArea = document.getElementById("assercoes-area");
        if(questao.assercoes && questao.assercoes.length > 0) {
            assercoesArea.style.display = "block";
            assercoesArea.innerHTML = questao.assercoes.join("<br><br>");
        } else {
            assercoesArea.style.display = "none";
        }

        const optionsArea = document.getElementById("options-area");
        optionsArea.innerHTML = ""; 
        
        const jaRespondida = progresso.respostas[questao.id] !== undefined;
        const respostaDada = progresso.respostas[questao.id];

        questao.alternativas.forEach((alt, index) => {
            const label = document.createElement("label");
            label.className = "option-label";
            if (jaRespondida) {
                if (index === questao.resposta_correta) label.classList.add("correct");
                else if (index === respostaDada) label.classList.add("incorrect");
            }
            
            const checked = (jaRespondida && respostaDada === index) ? "checked" : "";
            const disabled = jaRespondida ? "disabled" : "";
            
            label.innerHTML = `<input type="radio" name="opcao" value="${index}" ${checked} ${disabled}> ${alt}`;
            optionsArea.appendChild(label);
        });

        // Controles de Botões
        document.getElementById("prev-btn").disabled = (currentIndex === 0);
        document.getElementById("next-btn").disabled = (currentIndex === questoes.length - 1);
        
        const submitBtn = document.getElementById("submit-btn");
        
        if (jaRespondida) {
            submitBtn.style.display = "none";
            mostrarFeedback(questao, respostaDada);
        } else {
            submitBtn.style.display = "block";
            submitBtn.disabled = false;
            document.getElementById("feedback-area").style.display = "none";
        }
    }

    function verificarResposta() {
        const opcoes = document.getElementsByName("opcao");
        let selecionada = -1;
        for (let i = 0; i < opcoes.length; i++) {
            if (opcoes[i].checked) { selecionada = parseInt(opcoes[i].value); break; }
        }

        if (selecionada === -1) {
            alert("Selecione uma alternativa antes de responder!");
            return;
        }

        const questao = questoes[currentIndex];
        progresso.respostas[questao.id] = selecionada;

        if (selecionada === questao.resposta_correta) { progresso.acertos++; } 
        else { progresso.erros++; }

        salvarProgresso();
        carregarQuestao(); 
    }

    function mostrarFeedback(questao, respostaDada) {
        const feedbackArea = document.getElementById("feedback-area");
        const feedbackTitle = document.getElementById("feedback-title");
        const feedbackExp = document.getElementById("feedback-explanation");

        feedbackArea.className = "feedback"; 
        if (respostaDada === questao.resposta_correta) {
            feedbackArea.classList.add("correct-box");
            feedbackTitle.innerText = "Mandou bem! Resposta Correta.";
        } else {
            feedbackArea.classList.add("incorrect-box");
            feedbackTitle.innerText = "Ops! Resposta Incorreta.";
        }

        feedbackExp.innerHTML = questao.explicacao;
        feedbackArea.style.display = "block";
    }

    function zerarSimulado() {
        if(confirm("Tem certeza que deseja apagar todo o seu progresso? Isso não pode ser desfeito.")) {
            localStorage.removeItem('simulado_psicologia_v2');
            progresso = { respostas: {}, acertos: 0, erros: 0 };
            irParaQuestao(0);
            atualizarEstatisticas();
        }
    }

    window.onload = initQuiz;
</script>

